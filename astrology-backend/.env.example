NODE_ENV=development
PORT=6000

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=astrology

# Optional legacy: X-Admin-Key header when set (admin JWT from /admin/login is primary)
ADMIN_API_KEY=

JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# Transit reminder emails (optional — omit to skip sending)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=App Name <you@gmail.com>
